# ── BNB Chain ────────────────────────────────────────────────────────────────
BNB_RPC_URL=https://bsc-dataseed.binance.org/
MERCHANT_PRIVATE_KEY=your_wallet_private_key_here
MERCHANT_WALLET_ADDRESS=your_wallet_address_here

# BEP-20 contracts (BNB Chain Mainnet — do not change)
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
USDC_CONTRACT=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev — SQLite, no setup needed
DATABASE_URL=sqlite+aiosqlite:///./stableflow.db
# Production — Render injects this automatically when Postgres is attached:
# DATABASE_URL=postgresql://user:password@host/dbname

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
WEBHOOK_SECRET=change-me-in-production

# ── AI (Claude) ───────────────────────────────────────────────────────────────
# Used ONLY for plain-English explanations of routing decisions.
# Leave blank to use template fallback — routing works without it.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
